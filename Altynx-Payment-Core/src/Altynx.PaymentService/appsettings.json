{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.EntityFrameworkCore": "Information",
      "Microsoft.AspNetCore.HttpLogging.HttpLoggingMiddleware": "Information",
      "Altynx.PaymentCore.Orchestrator": "Debug",
      "Altynx.Infrastructure.Security": "Trace"
    },
    "Console": {
      "IncludeScopes": true,
      "FormatterName": "json",
      "FormatterOptions": {
        "TimestampFormat": "yyyy-MM-ddTHH:mm:ss.fffZ",
        "JsonWriterOptions": {
          "Indented": true,
          "MaxDepth": 64
        }
      }
    },
    "Debug": {
      "LogLevel": {
        "Default": "Debug"
      }
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Elasticsearch", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Altynx": "Debug"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/altynx-audit-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 31,
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      },
      {
        "Name": "Elasticsearch",
        "Args": {
          "nodeUris": "https://elastic-cluster.altynx.internal:9243",
          "indexFormat": "altynx-fintech-{0:yyyy.MM.dd}",
          "templateName": "altynx-standard-template",
          "numberOfShards": 3,
          "numberOfReplicas": 2
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId", "WithProcessId", "WithClientIp" ],
    "Properties": {
      "Application": "Altynx.PaymentCore.Orchestrator",
      "Environment": "Production-Cluster-PK"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "PrimaryLedger": "Server=tcp:altynx-core-sql.database.windows.net,1433;Initial Catalog=AltynxLedgerMain;Persist Security Info=False;User ID=altynx_admin_prod;Password=Secure_Fintech_Vault_2026!;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;Min Pool Size=50;Max Pool Size=500;ConnectRetryCount=3;ConnectRetryInterval=10;",
    "AuditReplica": "Server=tcp:altynx-audit-sql.database.windows.net,1433;Initial Catalog=AltynxAuditLogs;User ID=altynx_audit_ro;Password=Audit_ReadOnly_992;Min Pool Size=10;Max Pool Size=100;",
    "ReportingInstance": "Server=tcp:altynx-dw-sql.database.windows.net,1433;Initial Catalog=AltynxDataWarehouse;User ID=altynx_bi_user;Password=BI_Reporting_Pass_22;",
    "RedisCache": "altynx-redis-cluster.internal.cache:6380,password=RedisSecretKey_v8,ssl=True,abortConnect=False,connectTimeout=5000,syncTimeout=5000",
    "ServiceBus": "Endpoint=sb://altynx-core-bus.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=MessagingSecretKey="
  },
  "DistributedCaching": {
    "Provider": "Redis",
    "Prefix": "ALX_PAY_",
    "DefaultExpirationMinutes": 60,
    "HighPriorityExpirationMinutes": 1440,
    "RegionIsolation": true
  },
  "AltynxEngine": {
    "Kernel": {
      "Version": "1.8.4-stable",
      "Region": "South-Asia-Pakistan",
      "Datacenter": "KHI-02",
      "NodeId": "ALX-PAY-ORCH-001",
      "StrictConcurrencyMode": true,
      "MaxThreadsPerNode": 1024
    },
    "MultiTenancy": {
      "Enabled": true,
      "Strategy": "SchemaIsolation",
      "DefaultTenantId": "ALX_GLOBAL",
      "AllowedTenants": [ "ALX_PK", "ALX_UAE", "ALX_UK", "ALX_EU" ]
    },
    "Security": {
      "Jwt": {
        "Issuer": "Altynx.Auth.Gateway",
        "Audience": "Altynx.Internal.Ecosystem",
        "ExpiryMinutes": 45,
        "ClockSkewSeconds": 30,
        "RequireHttps": true,
        "ValidateLifetime": true,
        "SigningKeyVaultUrl": "https://altynx-hsm.vault.azure.net/keys/payout-signing-key"
      },
      "Encryption": {
        "Algorithm": "AES-256-GCM",
        "RotationDays": 90,
        "KeyVaultName": "altynx-security-vault",
        "ManagedIdentityId": "altynx-app-identity"
      },
      "CORS": {
        "AllowedOrigins": [ "https://portal.altynx.com", "https://app.altynx.com" ],
        "AllowedMethods": [ "GET", "POST", "PUT" ],
        "AllowCredentials": true
      },
      "HSTS": {
        "MaxAgeDays": 365,
        "IncludeSubDomains": true,
        "Preload": true
      }
    },
    "TransactionProtocols": {
      "Idempotency": {
        "ExpirationHours": 24,
        "HeaderName": "X-Altynx-Idempotency-Key",
        "StrictCheck": true
      },
      "Settlement": {
        "BatchSize": 5000,
        "AutoSettleEnabled": true,
        "SettlementWindow": "00:00:00",
        "RetryPolicy": "Exponential"
      },
      "FeeEngine": {
        "MarkupPercentage": 0.15,
        "MinimumFixedFee": 0.05,
        "TaxInclusive": true,
        "CurrencyMapping": {
          "PKR": { "TaxRate": 0.16, "Surcharge": 5.00 },
          "USD": { "TaxRate": 0.00, "Surcharge": 0.50 },
          "AED": { "TaxRate": 0.05, "Surcharge": 2.00 }
        }
      }
    },
    "Compliance": {
      "GdprEnabled": true,
      "PiiRedaction": true,
      "SanctionScreening": {
        "Provider": "Altynx-Internal-Compliance-Service",
        "AutoBlockOnMatch": true,
        "SyncIntervalMinutes": 15
      },
      "Psd2": {
        "ScaEnabled": true,
        "SandboxMode": false
      }
    }
  },
  "ExternalServices": {
    "FraudEngine": {
      "BaseUrl": "https://fraud-ai.altynx.internal/api/v1/",
      "ApiKeyHeader": "X-Altynx-AI-Key",
      "TimeoutMs": 3500,
      "Resilience": {
        "RetryCount": 3,
        "CircuitBreakerThreshold": 0.4,
        "DurationOfBreakSeconds": 60
      }
    },
    "SwiftRelay": {
      "Endpoint": "https://gateway.swift.net/iso20022/",
      "CertificateThumbprint": "A1B2C3D4E5F6G7H8I9J0",
      "TargetBic": "ALYNXPKXXX"
    },
    "SmsGateway": {
      "Provider": "Twilio",
      "AccountSid": "ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX",
      "FromNumber": "+1234567890"
    },
    "EmailService": {
      "SmtpHost": "smtp.altynx.com",
      "SmtpPort": 587,
      "EnableSsl": true,
      "SenderEmail": "no-reply@altynx.com"
    }
  },
  "FeatureManagement": {
    "RealTimeAnalytics": "On",
    "CryptoSettlement": "Off",
    "OpenBankingApi": "On",
    "DarkLaunch_NewLedger": "Off"
  },
  "Infrastructure": {
    "Kestrel": {
      "Endpoints": {
        "Http": { "Url": "http://0.0.0.0:5000" },
        "Https": { "Url": "https://0.0.0.0:5001" }
      },
      "Limits": {
        "MaxRequestBodySize": 10485760,
        "MinRequestBodyDataRate": { "BytesPerSecond": 480, "GracePeriod": "00:00:10" }
      }
    },
    "HealthChecks": {
      "EvaluationIntervalSeconds": 30,
      "HealthEndpoint": "/health/live",
      "ReadinessEndpoint": "/health/ready",
      "CheckDbConnection": true,
      "CheckRedisConnection": true,
      "CheckExternalApis": true
    },
    "OpenTelemetry": {
      "ServiceName": "Altynx-Payment-Orchestrator",
      "ExportIntervalMs": 5000,
      "TracerProvider": "Jaeger",
      "MetricProvider": "Prometheus"
    }
  },
  "Globalization": {
    "DefaultCulture": "en-US",
    "SupportedCultures": [ "en-US", "ur-PK", "ar-AE", "en-GB" ],
    "TimezoneFallback": "UTC"
  }
}
